DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-application-id

# Authentication — use ONE of these:
CLAUDE_CODE_OAUTH_TOKEN=your-claude-oauth-token       # Claude Max subscription (run: claude setup-token)
# ANTHROPIC_API_KEY=sk-ant-api03-...                  # Anthropic API key (pay per usage)
SESSION_CATEGORY_NAME=CLAUDE SESSIONS

# Where to persist Discord<->session mappings.
#   Docker:  /data/sessions.json (matches the named volume in docker-compose.yml)
#   Native:  ./data/sessions.json or any writable absolute path
# If unset: defaults to ~/.mindbridge/sessions.json (see src/config.ts).
# SESSION_FILE_PATH=/data/sessions.json

# Path to the Claude Code CLI binary.
#   macOS / Linux: typically just `claude` on PATH
#   Windows:       npm-installed CLIs ship as `claude.cmd`; the bot auto-detects
#                  this when CLAUDE_CLI_PATH is `claude` (no extension), but you
#                  may set it explicitly to `claude.cmd` if auto-detection fails
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_TIMEOUT=86400000

# Working directory Claude operates in.
#   Docker:  /workspace (matches the workspace mount in docker-compose.yml)
#   Native:  absolute path to your project root, e.g. /Users/you/Documents/workspace
# If unset: defaults to process.cwd() — usually the bot's own repo, which is
# almost never what you want. Set this explicitly for native deployments.
# CLAUDE_WORK_DIR=/workspace

# Docker only: directory mounted at /workspace inside the container.
# Default is ${HOME}/workspace. To preserve the legacy default, set:
#   WORKSPACE_PATH=${HOME}/Documents/workspace
# WORKSPACE_PATH=

LOG_LEVEL=info
